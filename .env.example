# Supabase (Configuración Core y RLS)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudflare R2 (Almacenamiento de archivos y fotos)
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=your_r2_bucket_name
CLOUDFLARE_R2_ENDPOINT=your_r2_endpoint_url
NEXT_PUBLIC_R2_PUBLIC_URL=your_r2_public_delivery_url

# Cloudinary (Entrega e imágenes de catálogo)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Resend (Correos Transaccionales)
RESEND_API_KEY=your_resend_api_key

# Dominio Base de la Plataforma (para el Middleware)
NEXT_PUBLIC_ROOT_DOMAIN=rutaslima.app

# Google OAuth (Credenciales de Cliente)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Vercel Integration (Conexión de la API y el CLI del Agente)
VERCEL_TOKEN=your_vercel_token
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_TEAM_ID=your_vercel_team_id
